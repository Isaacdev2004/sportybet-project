# ---- PinnOdds (https://pinnodds.com) ----
PINNACLE_API_KEY=

# Trial / REST-only: poll GET /api/drops (use when SSE /odds-drop returns 403)
PINNACLE_USE_DROPS_POLL=true

# Poll interval ms (default 900000 = 15 min). Trial quotas are tight—increase if you hit 429.
PINNACLE_DROPS_POLL_MS=900000

# live | prematch
PINNACLE_DROPS_MODE=live
PINNACLE_DROPS_LIMIT=80

# Optional: PINNACLE_DROPS_MIN_DROP_PCT=7

# Drops newer than this many seconds when polling (0 = omit from request)
PINNACLE_DROPS_MAX_AGE_SEC=600

# Max parallel /kit/v1/details requests (trial=keep at 1–2 or you will 429 instantly)
PINNACLE_DETAILS_MAX_CONCURRENT=2

# When SSE/drops expose nvp on totals-style markets, use it and skip dewag fetch (omit or true).
# PINNACLE_PREFER_PROVIDER_NVP=false to always compute NVP locally from two-way totals.
PINNACLE_PREFER_PROVIDER_NVP=

PINNACLE_API_BASE=https://pinnodds.com
PINNACLE_SSE_PATH=odds-drop
# Full streaming URL (invite `token=` for odds-drop). Your portal API key is still required:
# PINNACLE_API_KEY=<from dashboard>
# PINNACLE_SSE_URL=https://pinnodds.com/odds-drop?token=YOUR_DROP_TOKEN
# The app adds ?key=… from PINNACLE_API_KEY if missing (SSE often ignores headers).
PINNACLE_SSE_URL=
# Invite token from PinnOdds odds-drop link (?token=…). With PINNACLE_SSE_URL empty, this is merged into ?key=… for the same request.
PINNACLE_SSE_AUTH_TOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Min pause between Telegram messages when many alerts pile up (ms)
TELEGRAM_MIN_GAP_MS=350
# Drop new alerts if Telegram send queue is behind by more than this (ms). Prevents “finished match” bursts; raise if you see many backlog drops after 429.
TELEGRAM_MAX_QUEUE_MS=60000
# Suppress repeats of same game/market/EV-rounded alert (ms). 0 = off.
TELEGRAM_ALERT_DEDUPE_MS=90000

HOST=0.0.0.0
PORT=3000

# ---- Dashboard login (share with client; see client-dashboard-access.template.txt) ----
# Set BOTH so the browser shows a username/password prompt when visiting http://YOUR_IP:3000
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
# Set to false to require auth even for GET /health (default: health stays public when auth is on).
DASHBOARD_PUBLIC_HEALTH=true
LOG_LEVEL=info
LOG_DIR=logs

FILTER_MIN_EV_PERCENT=4
FILTER_EXCLUDED_LEAGUES=
# Comma-separated keys: tennis, basketball (+ feed aliases NBA, WNBA, Euroleague strings count as basketball)
FILTER_ALLOWED_SPORTS=tennis,basketball
FILTER_MIN_DROP_PERCENT=0
# Alert freshness window (ms). Drops older than this are ignored before EV/alert.
FILTER_SIGNAL_MAX_AGE_MS=10000
# Suppress alerts before kickoff or long after start (minutes; 0 = disable). Cuts late settlement noise.
FILTER_MAX_PLAYABLE_WINDOW_MINUTES=240
# When true, require isLive:true on the SSE event OR Pinnacle /details — period/scores/clock are not enough.
# If alerts disappear, your feed likely omits isLive; set false or ask the provider.
FILTER_REQUIRE_EXPLICIT_LIVE=false

HTTP_MAX_RETRIES=3
HTTP_RETRY_BASE_MS=100

# ---- Phase 2: SportyBet execution (Playwright) ----
# Master switch for automated placement after a passing opportunity.
EXECUTION_ENABLED=false
# Budget after Playwright lock (nav + stake). Real flows often need 25–45s; default 45000.
EXECUTION_MAX_MS=45000
# After acquiring the Playwright mutex, skip browser work if signal age exceeds this (ms). 0 = off. Default 180000 (3 min).
# EXECUTION_MAX_QUEUED_SIGNAL_AGE_MS=180000
# Parallel Playwright worker slots per account (each = own browser context). Default 4.
EXECUTION_ACCOUNT_WORKERS=4
# Stake per range: random in [min,max] (default). Set true to use midpoint instead.
# EXECUTION_STAKE_PICK_MIDPOINT=false
# EXECUTION_STAKE_ROUND_STEP=0
# Dedup: skip only identical event+market+line+selection within this window (ms). Default 30m.
EXECUTION_DEDUP_TTL_MS=1800000
# Page.goto timeout (ms). Default 32000 — fail a bit sooner on hung loads than 45s.
# EXECUTION_PAGE_GOTO_TIMEOUT_MS=32000
# Optional: trim artificial pauses (ms). Defaults tuned for speed without dropping reliability much.
# EXECUTION_NAV_SCROLL_SETTLE_MS=100
# EXECUTION_PLACE_BET_SETTLE_MS=40
# If live SportyBet odds differ from soft quote by more than this (absolute), skip.
EXECUTION_MAX_ODDS_DRIFT=0.05
# VPS has no GUI: keep true. prove:login / discover:sportybet-api auto-headless without $DISPLAY.
EXECUTION_HEADLESS=true
EXECUTION_SESSION_DIR=data/sessions
EXECUTION_ACCOUNTS_PATH=data/accounts.json
EXECUTION_SPORTYBET_BASE_URL=https://www.sportybet.com

# ---- SportyBet odds (priority: reverse-engineered API) ----
# Default odds source is API. Set SPORTYBET_ODDS_SOURCE=playwright|mock to override.
SPORTYBET_ODDS_SOURCE=api
# Record JSON XHR while browsing (catalog for RE). Use: SPORTYBET_API_CAPTURE=true npm run discover:sportybet-api
# SPORTYBET_API_CAPTURE=true
# SPORTYBET_API_CATALOG_PATH=data/sportybet_api_catalog.jsonl
# One or more path templates (semicolon-separated). Placeholders: {parentId} {line} {designation} {side} {sport} …
# SPORTYBET_API_ODDS_PATHS=/api/...
# Optional dot path into JSON: SPORTYBET_API_ODDS_JSON_PATH=data.outcomes.0.odds
# SPORTYBET_API_BASE_URL=https://www.sportybet.com
# SPORTYBET_API_AUTH_TOKEN=
# SPORTYBET_API_TIMEOUT_MS=12000
# SPORTYBET_API_USE_PLAYWRIGHT_TRANSPORT=true
# SPORTYBET_API_WORKER_SLOT=9
# discover:sportybet-api budgets (ms) — separate login vs each sport vertical
# EXECUTION_DISCOVER_LOGIN_BUDGET_MS=180000
# EXECUTION_DISCOVER_SPORT_BUDGET_MS=120000

# Playwright UI scrape (fallback when API templates are not set yet).
# SPORTYBET_LIVE_QUOTES=true
# If live probe fails, fall back to mock (label includes "mock · live unreadable"). Set false to skip as no soft match.
# SPORTYBET_LIVE_QUOTE_FALLBACK=true
# EXECUTION_SPORTYBET_BASE_URL=https://www.sportybet.com/ng
# If base URL already ends in /ng, set HOME_PATH to a single slash so URLs are not …/ng/ng:
# EXECUTION_HOME_PATH=/
# Session keepalive: background HTTP GET on the same interval (no extra browser tabs). 0 = off.
# EXECUTION_SESSION_KEEPALIVE_MS=240000
# Persistent execution log JSONL path (restart-safe ledger)
# EXECUTION_LEDGER_PATH=data/execution_ledger.jsonl

# Nigeria / deep navigation: skip home → sport clicks by opening vertical URLs directly:
# EXECUTION_DEEP_LINK_BASKETBALL_URL=https://www.sportybet.com/ng/sport/basketball/
# EXECUTION_DEEP_LINK_TENNIS_URL=https://www.sportybet.com/ng/sport/tennis
# EXECUTION_DEEP_LINK_LIVE_URL=https://www.sportybet.com/ng/sport/live/
# EXECUTION_DEEP_LINK_FOOTBALL_URL=https://www.sportybet.com/ng/sport/football/
# After goto, optionally click Live if that tab appears (omit or true; set false if URL is already live-only).
# EXECUTION_DEEP_LINK_TRY_LIVE_CLICK=true

# DOM selectors — tune against live SportyBet. Match sessionManager.ts + directSportyBetNav.ts
# --- Login (see sessionManager.ts) ---
# EXECUTION_LOGIN_USER_SELECTOR=input[name="phone"]
# EXECUTION_LOGIN_PASS_SELECTOR=input[placeholder="Password"]
# EXECUTION_LOGIN_SUBMIT_SELECTOR=button:has-text("Login")
# EXECUTION_LOGGED_IN_SELECTOR=

# --- Direct nav: Home path → Sport link → Live (no search; see directSportyBetNav.ts) ---
# EXECUTION_HOME_PATH=/ng/
# EXECUTION_SPORT_LINK_BASKETBALL/BASKETBALL defaults; override label if UI differs
# EXECUTION_LIVE_LINK_NAME=Live

# Live list: row selector + optional wait selector
# EXECUTION_LIVE_MATCH_ROW=
# EXECUTION_LIVE_LIST_READY=
# EXECUTION_LIVE_SCAN_MAX_ROWS=100

# Live match cache: TTL 30–60s, half-TTL background rescan, pre-warm after Live (see matchDiscoveryCache.ts)
# EXECUTION_MATCH_CACHE_TTL_MS=45000
# Optional: attribute order to find stable row id (first hit wins)
# EXECUTION_LIVE_ROW_STABLE_ATTRS=data-event-id,data-id,data-testid,id

# Market tabs (RegExp source inside new RegExp(...))
# EXECUTION_TAB_TOTALS=
# EXECUTION_TAB_SPREAD=
# EXECUTION_TAB_MONEYLINE=

# Outcome labels
# EXECUTION_OUTCOME_OVER_LABEL=Over
# EXECUTION_OUTCOME_UNDER_LABEL=Under

# Stake & place (bet slip)
# EXECUTION_STAKE_INPUT=
# EXECUTION_PLACE_BET=

# First odd shown for on-page drift vs softOdds (after selection)
# EXECUTION_ODDS_DISPLAY=

# npm run prove:login — keep browser until Enter (optional; otherwise closes after pause)
# EXECUTION_PROVE_LOGIN_WAIT_ENTER=true
# EXECUTION_PROVE_LOGIN_PAUSE_SEC=30
