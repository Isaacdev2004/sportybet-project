{
  "name": "value-betting-engine",
  "version": "1.0.0",
  "description": "Real-time value betting engine: Pinnacle SSE → NVP/EV → SportyBet compare → Telegram",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc && npm run build:client",
    "build:client": "npm --prefix client ci && npm --prefix client run build",
    "prestart": "npm run build",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "dev:ui": "npm --prefix client run dev",
    "prove:login": "tsx src/scripts/proveSportyBetLogin.ts",
    "discover:sportybet-api": "tsx src/scripts/discoverSportyBetApi.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "eventsource": "^2.0.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
